<?xml version="1.0"?>
<!--
  Minimal diff-drive robot for TD-MPC2 crop-following.
  Uses only standard gazebo_ros plugins (no custom C++ required).

  Published topics (relative to robot_ns arg):
    /<robot_ns>/ground_truth  [nav_msgs/Odometry]  — ground truth from p3d plugin
    /<robot_ns>/odom          [nav_msgs/Odometry]  — wheel odometry from diff_drive plugin
    /<robot_ns>/vision/camera/image_raw  [sensor_msgs/Image]  — forward camera

  Subscribed topics:
    /<robot_ns>/cmd_vel  [geometry_msgs/Twist]  — velocity command

  To replace with your own robot: swap this file and update the URDF path
  in terra_gazebo/launch/terra_gazebo.launch.
-->
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="robot_ns" default="robot"/>
  <xacro:property name="robot_ns" value="$(arg robot_ns)"/>

  <!-- ─── Links ─────────────────────────────────────────────────────── -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="0.50 0.35 0.15"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.50 0.35 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.8" iyz="0" izz="0.8"/>
    </inertial>
  </link>

  <!-- Left wheel -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.225 -0.055" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.13" length="0.05"/></geometry>
      <material name="dark"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.13" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- Right wheel -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.225 -0.055" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.13" length="0.05"/></geometry>
      <material name="dark"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.13" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- Front caster (frictionless) -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.2 0 -0.12" rpy="0 0 0"/>
  </joint>
  <link name="caster_link">
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="dark"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Forward camera -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.25 0 0.10" rpy="0 0 0"/>
  </joint>
  <link name="camera_link">
    <visual>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
      <material name="dark"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ─── Gazebo properties ──────────────────────────────────────────── -->

  <gazebo reference="left_wheel"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="right_wheel"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="caster_link"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <!-- ─── Plugins ───────────────────────────────────────────────────── -->

  <!-- Differential drive: subscribes /<robot_ns>/cmd_vel [Twist] -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <updateRate>50</updateRate>
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <wheelSeparation>0.45</wheelSeparation>
      <wheelDiameter>0.26</wheelDiameter>
      <torque>20</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <robotNamespace>${robot_ns}</robotNamespace>
      <publishWheelTF>false</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>false</publishWheelJointState>
      <legacyMode>false</legacyMode>
    </plugin>
  </gazebo>

  <!-- Ground truth odometry: publishes /<robot_ns>/ground_truth [Odometry] -->
  <gazebo>
    <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
      <frameName>world</frameName>
      <bodyName>base_link</bodyName>
      <topicName>/${robot_ns}/ground_truth</topicName>
      <updateRate>50</updateRate>
    </plugin>
  </gazebo>

  <!-- Forward camera: publishes /<robot_ns>/vision/camera/image_raw [Image] -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="front_camera">
      <update_rate>30.0</update_rate>
      <camera name="front_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>320</width>
          <height>224</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.02</near><far>300</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <robotNamespace>${robot_ns}/vision</robotNamespace>
        <cameraName>camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>camera_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
